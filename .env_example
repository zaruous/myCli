# ================================================================
# KYJ CLI 환경 설정 예시 (.env_example)
# 이 파일을 복사하여 .env 로 저장한 뒤 값을 채워주세요.
#   cp .env_example .env
# ================================================================

# ----------------------------------------------------------------
# 기본 AI 공급자 설정 (MYCLI_PROVIDER)
# ----------------------------------------------------------------
# 시작 시 사용할 AI 공급자를 지정합니다.
# 가능한 값: gemini | gpt | ollama | vllm
#
# 설정하지 않으면 아래 순서로 자동 감지합니다:
#   1. GOOGLE_API_KEY 있음 → gemini
#   2. OPENAI_API_KEY 있음 → gpt
#   3. 둘 다 없음         → ollama (로컬)
#
# 실행 중 '/model <provider>' 명령으로도 전환 가능합니다.
MYCLI_PROVIDER=ollama

# ----------------------------------------------------------------
# Google Gemini API 키
# ----------------------------------------------------------------
# https://aistudio.google.com/app/apikey 에서 발급
# MYCLI_PROVIDER=gemini 일 때 필요합니다.
GOOGLE_API_KEY=

# ----------------------------------------------------------------
# OpenAI API 키
# ----------------------------------------------------------------
# https://platform.openai.com/api-keys 에서 발급
# MYCLI_PROVIDER=gpt 일 때 필요합니다. (모델: gpt-4o)
OPENAI_API_KEY=

# ----------------------------------------------------------------
# Ollama 설정 (로컬 LLM)
# ----------------------------------------------------------------
# Ollama 서버 주소 — 기본값: http://localhost:11434
# 원격 서버 사용 시 해당 주소로 변경하세요.
OLLAMA_BASE_URL=http://localhost:11434

# 사용할 Ollama 모델 이름 (ollama list 로 확인)
# 예시: gemma3:1b, llama3, qwen2.5:7b, mistral
OLLAMA_MODEL=gemma3:1b

# ----------------------------------------------------------------
# vLLM 설정 (OpenAI 호환 로컬/원격 추론 서버)
# ----------------------------------------------------------------
# MYCLI_PROVIDER=vllm 일 때 사용됩니다.
# vLLM은 OpenAI 호환 API(/v1)를 사용하므로 ollama와 달리 별도 설정이 필요합니다.
VLLM_BASE_URL=http://localhost:8000

# vLLM에서 서빙 중인 모델 이름 (vllm serve 시 --model 로 지정한 값)
VLLM_MODEL=default

# vLLM API 키 (인증 없이 운영 시 EMPTY 그대로 사용)
VLLM_API_KEY=EMPTY

# ----------------------------------------------------------------
# 훅 이벤트 SQLite 로그
# ----------------------------------------------------------------
# 모든 훅 이벤트(PreUserPromptSubmit, PreToolCall, PostToolCall, Stop)를
# SQLite DB에 자동 기록합니다.
# 비활성화하려면 false 로 설정하세요. (기본값: true)
MYCLI_HOOK_LOG=true

# 로그 DB 파일 경로 (기본값: ~/.mycli/hook-log.db)
# 변경하려면 절대 경로로 지정하세요.
MYCLI_HOOK_LOG_DB=
